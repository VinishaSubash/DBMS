--AVERAGE PAYMENT PER MODE (FUNCTION)

SQL> create or replace function avg_payment_mode
  2  return varchar2
  3  is
  4      v_result varchar2(4000) := '';
  5  begin
  6      for rec in (
  7          select payment_mode, avg(amount) as avg_amt
  8          from payment
  9          group by payment_mode
 10      )
 11      loop
 12          v_result := v_result || rec.payment_mode || ' - ' || rec.avg_amt || chr(10);
 13      end loop;
 14      return v_result;
