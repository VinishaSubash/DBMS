--EVENT WITH MAXIMUM BOOKING (PROCEDURE)

SQL> create or replace procedure max_booking_event
  2  is
  3      v_event number;
  4  begin
  5      select event_id into v_event
  6      from (
  7          select event_id, count(*) cnt
  8          from booking
  9          group by event_id
 10          order by cnt desc
 11      )
 12      where rownum = 1;
 13      dbms_output.put_line('event with max bookings: ' || v_event);
 14  end;
 15  /

Procedure created.

SQL> exec max_booking_event;
event with max bookings: 1

PL/SQL procedure successfully completed.

--PAYMENTS GREATER THAN AVERGAE (PROCEDURE)

SQL> create or replace procedure payments_above_avg
  2  is
  3      v_avg number;
  4  begin
  5      select avg(amount) into v_avg from payment;
  6      for rec in (
  7          select payment_id, amount
  8          from payment
  9          where amount > v_avg
 10      )
 11      loop
 12          dbms_output.put_line(rec.payment_id || ' ' || rec.amount);
 13      end loop;
 14  end;
 15  /

