--DISPLAY ALL PAYMENT DETAILS (PROCEDURE)

SQL> create or replace procedure display_all_payments
  2  is
  3      cursor c is
  4          select payment_id, amount, payment_mode, payment_status
  5          from payment;
  6      v_id payment.payment_id%type;
  7      v_amt payment.amount%type;
  8      v_mode payment.payment_mode%type;
  9      v_status payment.payment_status%type;
 10  begin
 11      open c;
 12      loop
 13          fetch c into v_id, v_amt, v_mode, v_status;
 14          exit when c%notfound;
 15          dbms_output.put_line(v_id || ' ' || v_amt || ' ' || v_mode || ' ' || v_status);
 16      end loop;
 17      close c;
 18  end;
 19  /

