--HIGHEST PAYMENT PER EVENT (PROCEDURE)

SQL> create or replace procedure highest_payment_event
  2  is
  3      cursor event_cur is select distinct event_id from payment;
  4      cursor pay_cur(eid number) is
  5          select payment_id, amount
  6          from payment
  7          where event_id = eid;
  8      v_max number;
  9  begin
 10      for e in event_cur loop
 11          select max(amount) into v_max
 12          from payment
 13          where event_id = e.event_id;
 14          for p in pay_cur(e.event_id) loop
 15              if p.amount = v_max then
 16                  dbms_output.put_line('event: ' || e.event_id ||
 17                                       ' payment: ' || p.payment_id ||
 18                                       ' amount: ' || p.amount);
 19              end if;
 20          end loop;
 21      end loop;
 22  end;
 23  /

