--PREVENT DELETE IF CHILD EXISTS

SQL> create or replace trigger trg_prevent_delete_catering
  2  before delete on catering
  3  for each row
  4  declare
  5     v_count number;
  6  begin
  7     select count(*) into v_count
  8     from menu
  9     where catering_id = :old.catering_id;
 10     if v_count > 0 then
 11        raise_application_error(-20020,'cannot delete: child records exist');
 12     end if;
 13  end;
 14  /

